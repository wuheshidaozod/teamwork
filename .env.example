# ============================================================
# 复制本文件为 .env，填入自己的配置，.env 不会被提交到 git
# cp .env.example .env
# ============================================================

# ===== 必填：DeepSeek API Key =====
# 前往 https://platform.deepseek.com 注册获取
DEEPSEEK_API_KEY=sk-在这里填入你的密钥

# ===== 可选：备用模型 通义千问 =====
# 前往 https://dashscope.aliyun.com 获取
# QWEN_API_KEY=

# ===== 可选：Wikipedia 代理 =====
# 不填则自动读取系统（IE）代理，系统代理也没有则直连
# WIKIPEDIA_PROXY=http://127.0.0.1:10808
